{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Home Assistant",
      "type": "debugpy",
      "request": "launch",
      "module": "homeassistant",
      "justMyCode": false,
      "args": [
        "--config",
        "${workspaceFolder}/ha-dev/config",
        "--debug"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
